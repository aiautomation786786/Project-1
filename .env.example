# --- AI inference (server-side fallback when user has not set BYOK) ----------
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the default model
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Authentication (Clerk) -------------------------------------------------
# Sign-in is optional in Codian. Anonymous visitors can still analyse code,
# but signing in unlocks per-account features (in future: persistent BYOK,
# saved analysis history, etc.).
#
# Get both keys at https://dashboard.clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
